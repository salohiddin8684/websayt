# Frontend Environment Variables
# Copy this file to .env and fill in your actual values

# Server port for local development
PORT=8000

# API Configuration
# Update these URLs based on your deployment
AUTH_API_BASE_URL=http://localhost:5000/api
ANIME_API_BASE_URL=/.netlify/functions/anime

# Environment
NODE_ENV=development

# Optional: Analytics or other service keys
# GOOGLE_ANALYTICS_ID=
# SENTRY_DSN=
